{
  "name": "tandem-browser",
  "version": "0.9.0",
  "description": "AI-Human symbiotic browser — Kees & Robin browse as one",
  "main": "dist/main.js",
  "author": "Robin Waslander <keesbeest78@proton.me>",
  "license": "MIT",
  "scripts": {
    "dev": "tsc && npx electron .",
    "start": "xattr -cr node_modules/electron/dist/Electron.app 2>/dev/null; npm run compile && node scripts/run-electron.js",
    "compile": "tsc",
    "watch": "tsc -w",
    "build": "tsc && electron-builder",
    "mcp": "node dist/mcp/server.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run src/security/tests/",
    "test:extensions": "vitest run src/extensions/tests/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/adm-zip": "^0.5.7",
    "acorn": "^8.16.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "turndown": "^7.2.2",
    "ws": "^8.19.0"
  },
  "//": "Liquid Glass Lite — uncomment when package is ready",
  "// dependencies-future": {
    "@mblock/liquid-glass": "file:../liquid-glass-lite/packages/core"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "productName": "Tandem Browser",
  "build": {
    "appId": "com.tandem.browser",
    "files": [
      "dist/**/*",
      "shell/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
